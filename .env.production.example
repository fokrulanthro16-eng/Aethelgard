# ── Aethelgard Production Environment ────────────────────────────────────────
#
# Copy this file to .env.local (frontend) and backend/.env (backend),
# then fill in every value before deploying.
#
# IMPORTANT: Review the Production Readiness Checklist in README.md before
# going live. Auth, KMS, and email delivery are required blockers.
#
# Frontend variables (prefix NEXT_PUBLIC_ to expose to the browser)
# ──────────────────────────────────────────────────────────────────

# Full URL of your deployed FastAPI backend (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# ── Backend variables (set in backend/.env or Lambda env) ─────────────────────

APP_NAME=Aethelgard API
ENVIRONMENT=production

# AWS credentials — use IAM role on EC2/Lambda, not static keys
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=         ← prefer IAM role; only set if no role is available
# AWS_SECRET_ACCESS_KEY=     ← same as above

# DynamoDB
DYNAMODB_TABLE_NAME=Aethelgard_Vault
DYNAMODB_ENDPOINT_URL=       # leave blank for AWS; use http://localhost:8001 for local DynamoDB

# Encryption — REQUIRED: use KMS in production, not local mode
ENCRYPTION_MODE=kms
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/your-key-id-here
# LOCAL_MASTER_KEY=          # only for ENCRYPTION_MODE=local (development only)

# AI Family Guide — optional but recommended
# Without this key the system falls back to a deterministic guide (always works)
GEMINI_API_KEY=your-gemini-api-key-here

# Dead Man's Switch
DEAD_MAN_SWITCH_DAYS=90

# Nominee release token expiry window
RELEASE_TOKEN_EXPIRY_HOURS=72

# ── Production checklist reminders ───────────────────────────────────────────
#
# Before going live, confirm each item is addressed:
#
#   [ ] Authentication added to all /users/* and /vault/* routes (JWT / Cognito)
#   [ ] /admin/* and /demo/* routes protected or removed
#   [ ] ENCRYPTION_MODE=kms with a valid KMS_KEY_ID
#   [ ] Nominee email delivery wired up (SES / SendGrid)
#   [ ] CORS restricted to production domain in backend/app/main.py
#   [ ] HTTPS enforced at load balancer / reverse proxy
#   [ ] Legal review complete for estate document storage
#   [ ] TransactWriteItems used for atomic token + status updates
