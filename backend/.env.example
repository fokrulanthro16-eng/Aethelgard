APP_NAME=Aethelgard API
ENVIRONMENT=development

# ── AWS credentials ───────────────────────────────────────────────────────────
# For real AWS: set your actual credentials (or rely on ~/.aws/credentials / IAM role).
# For local dev with moto: any non-empty values work — moto doesn't validate them.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# ── DynamoDB ──────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=Aethelgard_Vault
DEAD_MAN_SWITCH_DAYS=90

# Local DynamoDB endpoint (moto server or DynamoDB Local).
# Leave blank to use real AWS DynamoDB.
#
# Option A — moto server (already installed, no extra downloads):
#   pip install flask flask-cors   # only needed once
#   python -m moto.server -p 5001  # start before uvicorn
#   DYNAMODB_ENDPOINT_URL=http://localhost:5001
#
# Option B — DynamoDB Local (requires Java 11+):
#   Download from https://docs.aws.amazon.com/amazondynamodb/latest/developerguide/DynamoDBLocal.html
#   java -Djava.library.path=./DynamoDBLocal_lib -jar DynamoDBLocal.jar -sharedDb -port 8001
#   DYNAMODB_ENDPOINT_URL=http://localhost:8001
#
DYNAMODB_ENDPOINT_URL=

# ── Encryption ────────────────────────────────────────────────────────────────
# "local" uses HKDF + LOCAL_MASTER_KEY (dev/single-instance).
# "kms"   uses AWS KMS envelope encryption (production).
ENCRYPTION_MODE=local

# Required when ENCRYPTION_MODE=local.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: rotating this key makes all existing vault ciphertext unreadable.
LOCAL_MASTER_KEY=replace-with-a-64-char-hex-string-generated-locally

# Required when ENCRYPTION_MODE=kms. ARN or alias of the AWS KMS CMK.
KMS_KEY_ID=

# Release token expiry window (hours). Default: 72 h (3 days).
RELEASE_TOKEN_EXPIRY_HOURS=72

# Optional AI integration
GEMINI_API_KEY=
